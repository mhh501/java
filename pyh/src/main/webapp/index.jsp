<%@ page contentType="text/html;charset=UTF-8" language="java" %><%@ taglib prefix="c" uri="jakarta.tags.core" %>
<!DOCTYPE html><html><head><meta charset="UTF-8"><title>票映汇衣橱</title><link rel="stylesheet" href="${pageContext.request.contextPath}/css/style.css"></head><body>
<aside class="sidebar"><div class="sidebar-logo">票映汇<span>网上衣橱</span></div><ul class="sidebar-nav"><li><a href="${pageContext.request.contextPath}/clothes"><span class="icon">🏠</span>首页</a></li><c:if test="${not empty sessionScope.loginUser}"><li><a href="${pageContext.request.contextPath}/cart"><span class="icon">🛒</span>购物车</a></li><li><a href="${pageContext.request.contextPath}/order"><span class="icon">📦</span>我的订单</a></li><li><a href="${pageContext.request.contextPath}/profile"><span class="icon">👤</span>个人中心</a></li><c:if test="${sessionScope.userRole=='admin'}"><li><a href="${pageContext.request.contextPath}/admin/dashboard"><span class="icon">⚙️</span>后台管理</a></li></c:if></c:if><c:if test="${empty sessionScope.loginUser}"><li><a href="${pageContext.request.contextPath}/login.jsp"><span class="icon">🔑</span>登录</a></li><li><a href="${pageContext.request.contextPath}/register.jsp"><span class="icon">📝</span>注册</a></li></c:if></ul><c:if test="${not empty sessionScope.loginUser}"><div class="sidebar-user"><span class="name">${sessionScope.loginUser}</span><span class="role">${sessionScope.userRole}</span><a href="${pageContext.request.contextPath}/login.jsp">退出登录</a></div></c:if></aside>
<div class="main-wrap"><div class="top-strip"><h1>服装列表</h1><form class="search-box" action="${pageContext.request.contextPath}/clothes"><input type="text" name="keyword" value="${keyword}" placeholder="搜索服装..."><select name="category"><option value="">全部分类</option><c:forEach items="${categories}" var="c"><option value="${c}" ${selectedCategory eq c?'selected':''}>${c}</option></c:forEach></select><select name="style"><option value="">全部风格</option><c:forEach items="${styles}" var="s"><option value="${s}" ${selectedStyle eq s?'selected':''}>${s}</option></c:forEach></select><button type="submit" class="btn btn-primary">搜索</button></form></div><div class="content"><div class="clothes-list"><c:forEach items="${clothesList}" var="cloth"><div class="clothes-row"><div style="width:120px;height:120px;border-radius:8px;background:linear-gradient(135deg,#e8dcc8,#d4c4a8);display:flex;align-items:center;justify-content:center;overflow:hidden;flex-shrink:0"><c:if test="${not empty cloth.imageUrl}"><img src="${pageContext.request.contextPath}/${cloth.imageUrl}" style="width:100%;height:100%;object-fit:cover"></c:if><c:if test="${empty cloth.imageUrl}"><span style="font-size:36px">👕</span></c:if></div><div class="info"><h3><a href="${pageContext.request.contextPath}/detail?id=${cloth.id}">${cloth.name}</a></h3><div class="meta"><span>${cloth.category}</span><span>${cloth.style}</span></div></div><div><span class="price">&yen;${cloth.price}</span><span class="stock">库存:${cloth.stock}</span></div><div class="actions"><a href="${pageContext.request.contextPath}/detail?id=${cloth.id}" class="btn btn-outline btn-sm">详情</a></div></div></c:forEach><c:if test="${empty clothesList}"><div class="empty-state"><div class="icon">👕</div><p>暂无服装，请添加后再来</p></div></c:if></div></div></div></body></html>