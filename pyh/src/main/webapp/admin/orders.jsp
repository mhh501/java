<%@ page contentType="text/html;charset=UTF-8" language="java" %><%@ taglib prefix="c" uri="jakarta.tags.core" %>
<!DOCTYPE html><html><head><meta charset="UTF-8"><title>订单管理 - 票映汇衣橱</title><link rel="stylesheet" href="${pageContext.request.contextPath}/css/admin.css"></head><body>
<aside class="admin-sidebar"><h2>后台管理</h2><ul><li><a href="${pageContext.request.contextPath}/admin/dashboard">控制面板</a></li><li><a href="${pageContext.request.contextPath}/admin/clothes">服装管理</a></li><li><a href="${pageContext.request.contextPath}/admin/orders" class="active">订单管理</a></li><li><a href="${pageContext.request.contextPath}/admin/users">用户管理</a></li></ul><div class="sidebar-footer"><a href="${pageContext.request.contextPath}/clothes" class="btn btn-outline btn-sm btn-block">返回前台</a></div></aside>
<div class="admin-main"><h1>订单管理</h1><table class="data-table"><tr><th>ID</th><th>订单号</th><th>用户</th><th>金额</th><th>状态</th><th>时间</th><th>操作</th></tr><c:forEach items="${orders}" var="o"><tr><td>${o.id}</td><td>${o.orderNo}</td><td>${o.userName}</td><td>&yen;${o.totalPrice}</td><td><span class="tag tag-${o.status}">${o.statusText}</span></td><td>${o.createTime}</td><td><c:if test="${o.status=='unshipped'}"><a href="${pageContext.request.contextPath}/admin/orders?action=ship&id=${o.id}" class="btn btn-success btn-sm" onclick="return confirm('确认发货？')">发货</a></c:if></td></tr></c:forEach></table></div></body></html>