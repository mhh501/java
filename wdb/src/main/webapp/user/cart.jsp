<%@ page contentType="text/html;charset=UTF-8" language="java" %><%@ taglib prefix="c" uri="jakarta.tags.core" %>
<!DOCTYPE html><html><head><meta charset="UTF-8"><title>购物车 - 微订宝衣橱</title><link rel="stylesheet" href="${pageContext.request.contextPath}/css/style.css"></head><body>
<header class="topbar"><div class="logo"><a href="${pageContext.request.contextPath}/clothes" style="color:#d45d3e">微订宝衣橱</a></div><ul class="nav-link"><li><a href="${pageContext.request.contextPath}/clothes">首页</a></li><li><a href="${pageContext.request.contextPath}/cart">购物车</a></li><li><a href="${pageContext.request.contextPath}/order">订单</a></li><li><a href="${pageContext.request.contextPath}/profile">个人中心</a></li><li><a href="${pageContext.request.contextPath}/login.jsp">退出</a></li></ul></header>
<div class="container"><h2 class="section-title">🛒 购物车</h2><c:if test="${empty cartItems}"><div class="empty-state"><div class="icon">🛒</div><p>购物车空空如也</p><a href="${pageContext.request.contextPath}/clothes" class="btn btn-primary mt-20">去逛逛</a></div></c:if><c:if test="${not empty cartItems}"><table class="cart-table"><tr><th>图片</th><th>名称</th><th>尺码</th><th>单价</th><th>数量</th><th>小计</th><th>操作</th></tr><c:forEach items="${cartItems}" var="item"><c:set var="sub" value="${item.price>0?item.price:item.clothesPrice}"/><tr><td><div style="width:60px;height:60px;border-radius:8px;background:linear-gradient(135deg,#f5d5c8,#e8b8a0);display:flex;align-items:center;justify-content:center;overflow:hidden"><c:if test="${not empty item.clothesImage}"><img src="${pageContext.request.contextPath}/${item.clothesImage}" style="width:100%;height:100%;object-fit:cover"></c:if><c:if test="${empty item.clothesImage}">👕</c:if></div></td><td>${item.clothesName}</td><td>${item.size}</td><td>&yen;${sub}</td><td><form action="${pageContext.request.contextPath}/cart" method="post" style="display:inline"><input type="hidden" name="action" value="update"><input type="hidden" name="id" value="${item.id}"><input type="number" name="quantity" value="${item.quantity}" min="1" style="width:50px;padding:4px;border-radius:6px;border:1px solid #f0d8cc;text-align:center" onchange="this.form.submit()"></form></td><td style="font-weight:700;color:#c0392b">&yen;${sub*item.quantity}</td><td><a href="${pageContext.request.contextPath}/cart?action=delete&id=${item.id}" class="btn btn-danger btn-sm" onclick="return confirm('确定删除？')">删除</a></td></tr></c:forEach></table><div class="cart-foot"><span style="font-size:18px;font-weight:800">合计: <strong style="color:#c0392b"></strong></span><a href="${pageContext.request.contextPath}/cart?action=checkout" class="btn btn-primary btn-lg" onclick="return confirm('确认结算？')">立即结算</a></div></c:if></div></body></html>