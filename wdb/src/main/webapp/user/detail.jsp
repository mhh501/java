<%@ page contentType="text/html;charset=UTF-8" language="java" %><%@ taglib prefix="c" uri="jakarta.tags.core" %>
<!DOCTYPE html><html><head><meta charset="UTF-8"><title>${cloth.name} - 微订宝衣橱</title><link rel="stylesheet" href="${pageContext.request.contextPath}/css/style.css"></head><body>
<header class="topbar"><div class="logo"><a href="${pageContext.request.contextPath}/clothes" style="color:#d45d3e">微订宝衣橱</a></div><ul class="nav-link"><li><a href="${pageContext.request.contextPath}/clothes">首页</a></li><c:if test="${not empty sessionScope.loginUser}"><li><a href="${pageContext.request.contextPath}/cart">购物车</a></li><li><a href="${pageContext.request.contextPath}/order">订单</a></li><li><a href="${pageContext.request.contextPath}/profile">个人中心</a></li></c:if></ul></header>
<div class="container"><a href="${pageContext.request.contextPath}/clothes" style="color:#a08070;font-size:13px;display:inline-block;margin-bottom:14px">&larr; 返回列表</a><div class="detail-split"><div class="split-img"><c:if test="${not empty cloth.imageUrl}"><img src="${pageContext.request.contextPath}/${cloth.imageUrl}"></c:if><c:if test="${empty cloth.imageUrl}"><span class="ph">👕</span></c:if></div><div class="split-info"><h2>${cloth.name}</h2><div class="chip-row"><span class="chip">${cloth.category}</span><span class="chip">${cloth.style}</span><span class="chip">库存: ${cloth.stock}</span></div><div class="price-big">&yen;${cloth.price}</div><p class="desc-text">${cloth.description}</p><c:if test="${not empty sessionScope.loginUser}"><form action="${pageContext.request.contextPath}/cart" method="post"><input type="hidden" name="action" value="add"><input type="hidden" name="clothesId" value="${cloth.id}"><div class="form-group"><label>选择尺码</label><div class="size-row"><c:forEach items="${sizeList}" var="sz"><label class="size-chip" onclick="document.querySelectorAll('.size-chip').forEach(el=>el.classList.remove('selected'));this.classList.add('selected')"><input type="radio" name="size" value="${sz}" style="display:none">${sz}</label></c:forEach></div></div><div class="form-group"><label>数量</label><input type="number" name="quantity" value="1" min="1" max="${cloth.stock}" style="width:80px"></div><button type="submit" class="btn btn-primary btn-lg">加入购物车</button></form></c:if><c:if test="${empty sessionScope.loginUser}"><a href="${pageContext.request.contextPath}/login.jsp" class="btn btn-primary btn-lg">登录后购买</a></c:if></div></div></div></body></html>