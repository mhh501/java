<%@ page contentType="text/html;charset=UTF-8" language="java" %><%@ taglib prefix="c" uri="jakarta.tags.core" %>
<!DOCTYPE html><html><head><meta charset="UTF-8"><title>微订宝衣橱</title><link rel="stylesheet" href="${pageContext.request.contextPath}/css/style.css"></head><body>
<header class="topbar"><div class="logo">微订宝衣橱</div><ul class="nav-link"><li><a href="${pageContext.request.contextPath}/clothes">首页</a></li><c:if test="${not empty sessionScope.loginUser}"><li><a href="${pageContext.request.contextPath}/cart">购物车</a></li><li><a href="${pageContext.request.contextPath}/order">订单</a></li><li><a href="${pageContext.request.contextPath}/profile">个人中心</a></li><c:if test="${sessionScope.userRole=='admin'}"><li><a href="${pageContext.request.contextPath}/admin/dashboard">后台</a></li></c:if><li><a href="${pageContext.request.contextPath}/login.jsp">退出</a></li></c:if><c:if test="${empty sessionScope.loginUser}"><li><a href="${pageContext.request.contextPath}/login.jsp">登录</a></li><li><a href="${pageContext.request.contextPath}/register.jsp">注册</a></li></c:if></ul><c:if test="${not empty sessionScope.loginUser}"><span class="user-chip">${sessionScope.loginUser}</span></c:if></header>
<div class="search-strip"><form action="${pageContext.request.contextPath}/clothes" style="display:flex;gap:10px;flex:1"><input type="text" name="keyword" value="${keyword}" placeholder="搜索服装..."><select name="category"><option value="">全部分类</option><c:forEach items="${categories}" var="c"><option value="${c}" ${selectedCategory eq c?'selected':''}>${c}</option></c:forEach></select><select name="style"><option value="">全部风格</option><c:forEach items="${styles}" var="s"><option value="${s}" ${selectedStyle eq s?'selected':''}>${s}</option></c:forEach></select><button type="submit">搜索</button></form></div>
<div class="container"><div class="item-list"><c:forEach items="${clothesList}" var="cloth"><div class="item-row"><div class="item-img"><c:if test="${not empty cloth.imageUrl}"><img src="${pageContext.request.contextPath}/${cloth.imageUrl}"></c:if><c:if test="${empty cloth.imageUrl}"><span style="font-size:32px">👕</span></c:if></div><div class="item-body"><h3><a href="${pageContext.request.contextPath}/detail?id=${cloth.id}">${cloth.name}</a></h3><div class="item-meta"><span>${cloth.category}</span><span>${cloth.style}</span></div></div><div><span class="item-price">&yen;${cloth.price}</span><span class="item-stock">库存${cloth.stock}</span></div><div><a href="${pageContext.request.contextPath}/detail?id=${cloth.id}" class="btn btn-outline btn-sm">详情</a></div></div></c:forEach><c:if test="${empty clothesList}"><div class="empty-state"><div class="icon">👕</div><p>暂无服装</p></div></c:if></div></div></body></html>