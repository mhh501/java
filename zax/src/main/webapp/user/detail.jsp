<%@ page contentType="text/html;charset=UTF-8" language="java" %><%@ taglib prefix="c" uri="jakarta.tags.core" %>
<!DOCTYPE html><html><head><meta charset="UTF-8"><title>${cloth.name} - 智安行衣橱</title><link rel="stylesheet" href="${pageContext.request.contextPath}/css/style.css"></head><body>
<nav class="nav-bar"><div class="logo"><a href="${pageContext.request.contextPath}/clothes" style="color:#1a2d35">智安行衣橱</a></div><ul class="nav-links"><li><a href="${pageContext.request.contextPath}/clothes">首页</a></li><c:if test="${not empty sessionScope.loginUser}"><li><a href="${pageContext.request.contextPath}/cart">购物车</a></li><li><a href="${pageContext.request.contextPath}/order">订单</a></li><li><a href="${pageContext.request.contextPath}/profile">个人中心</a></li></c:if></ul></nav>
<div class="detail-hero"><div class="detail-img"><c:if test="${not empty cloth.imageUrl}"><img src="${pageContext.request.contextPath}/${cloth.imageUrl}"></c:if><c:if test="${empty cloth.imageUrl}"><div class="placeholder">👕</div></c:if></div><div class="detail-main"><a href="${pageContext.request.contextPath}/clothes" style="color:rgba(255,255,255,.5);font-size:13px;display:inline-block;margin-bottom:12px">&larr; 返回</a><h2>${cloth.name}</h2><div class="tags"><span>${cloth.category}</span><span>${cloth.style}</span><span>库存: ${cloth.stock}</span></div><div class="price-hero">&yen;${cloth.price}</div></div></div>
<div class="detail-body"><div class="detail-desc"><p>${cloth.description}</p></div><div class="detail-action"><c:if test="${not empty sessionScope.loginUser}"><form action="${pageContext.request.contextPath}/cart" method="post"><input type="hidden" name="action" value="add"><input type="hidden" name="clothesId" value="${cloth.id}"><div class="form-group"><label>选择尺码</label><div class="size-grid"><c:forEach items="${sizeList}" var="sz"><label class="size-tag" onclick="document.querySelectorAll('.size-tag').forEach(el=>el.classList.remove('selected'));this.classList.add('selected')"><input type="radio" name="size" value="${sz}" style="display:none">${sz}</label></c:forEach></div></div><div class="qty-row"><span>数量:</span><input type="number" name="quantity" value="1" min="1" max="${cloth.stock}"></div><button type="submit" class="btn btn-primary btn-lg btn-block">加入购物车</button></form></c:if><c:if test="${empty sessionScope.loginUser}"><a href="${pageContext.request.contextPath}/login.jsp" class="btn btn-primary btn-lg btn-block">登录后购买</a></c:if></div></div></body></html>