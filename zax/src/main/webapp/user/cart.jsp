<%@ page contentType="text/html;charset=UTF-8" language="java" %><%@ taglib prefix="c" uri="jakarta.tags.core" %>
<!DOCTYPE html><html><head><meta charset="UTF-8"><title>购物车 - 智安行衣橱</title><link rel="stylesheet" href="${pageContext.request.contextPath}/css/style.css"></head><body>
<nav class="nav-bar"><div class="logo"><a href="${pageContext.request.contextPath}/clothes" style="color:#1a2d35">智安行衣橱</a></div><ul class="nav-links"><li><a href="${pageContext.request.contextPath}/clothes">首页</a></li><li><a href="${pageContext.request.contextPath}/cart">购物车</a></li><li><a href="${pageContext.request.contextPath}/order">订单</a></li><li><a href="${pageContext.request.contextPath}/profile">个人中心</a></li><li><a href="${pageContext.request.contextPath}/login.jsp">退出</a></li></ul></nav>
<div class="cart-container"><h2 class="section-title">🛒 购物车</h2><c:if test="${empty cartItems}"><div class="empty-state"><div class="icon">🛒</div><p>购物车空空如也</p><a href="${pageContext.request.contextPath}/clothes" class="btn btn-primary mt-20">去逛逛</a></div></c:if><c:if test="${not empty cartItems}"><div class="cart-grid"><c:forEach items="${cartItems}" var="item"><c:set var="sub" value="${item.price>0?item.price:item.clothesPrice}"/><div class="cart-tile"><div style="width:90px;height:90px;border-radius:10px;background:linear-gradient(135deg,#d4dee3,#bcc8d0);display:flex;align-items:center;justify-content:center;overflow:hidden;flex-shrink:0"><c:if test="${not empty item.clothesImage}"><img src="${pageContext.request.contextPath}/${item.clothesImage}" style="width:100%;height:100%;object-fit:cover"></c:if><c:if test="${empty item.clothesImage}"><span>👕</span></c:if></div><div class="info"><h3 style="font-size:15px;margin-bottom:4px">${item.clothesName}</h3><p style="color:#7f8c9b;font-size:13px">尺码: ${item.size} | &yen;${sub}</p><form action="${pageContext.request.contextPath}/cart" method="post" style="display:inline;margin-top:6px"><input type="hidden" name="action" value="update"><input type="hidden" name="id" value="${item.id}"><input type="number" name="quantity" value="${item.quantity}" min="1" style="width:55px;padding:4px;border-radius:6px;border:1px solid #d8e0e6;text-align:center" onchange="this.form.submit()"></form></div><div><span style="font-size:18px;font-weight:700;color:#c0392b">&yen;${sub*item.quantity}</span></div><div><a href="${pageContext.request.contextPath}/cart?action=delete&id=${item.id}" class="btn btn-danger btn-sm" onclick="return confirm('确定删除？')">删除</a></div></div></c:forEach></div><div class="cart-summary"><span style="font-size:20px;font-weight:800">合计: <strong style="color:#c0392b">&yen;</strong></span><a href="${pageContext.request.contextPath}/cart?action=checkout" class="btn btn-primary btn-lg" onclick="return confirm('确认结算？')">立即结算</a></div></c:if></div></body></html>