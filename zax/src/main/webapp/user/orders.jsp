<%@ page contentType="text/html;charset=UTF-8" language="java" %><%@ taglib prefix="c" uri="jakarta.tags.core" %>
<!DOCTYPE html><html><head><meta charset="UTF-8"><title>我的订单 - 智安行衣橱</title><link rel="stylesheet" href="${pageContext.request.contextPath}/css/style.css"></head><body>
<nav class="nav-bar"><div class="logo"><a href="${pageContext.request.contextPath}/clothes" style="color:#1a2d35">智安行衣橱</a></div><ul class="nav-links"><li><a href="${pageContext.request.contextPath}/clothes">首页</a></li><li><a href="${pageContext.request.contextPath}/cart">购物车</a></li><li><a href="${pageContext.request.contextPath}/order">订单</a></li><li><a href="${pageContext.request.contextPath}/profile">个人中心</a></li><li><a href="${pageContext.request.contextPath}/login.jsp">退出</a></li></ul></nav>
<div class="cart-container"><h2 class="section-title">📦 我的订单</h2><c:if test="${empty orders}"><div class="empty-state"><div class="icon">📦</div><p>暂无订单</p></div></c:if><div class="order-timeline"><c:forEach items="${orders}" var="o"><div class="order-block"><div class="order-head"><span>${o.orderNo}</span><span style="font-size:12px;color:#7f8c9b">${o.createTime}</span><span class="tag tag-${o.status}">${o.statusText}</span></div><div class="order-core"><div><c:forEach items="${o.items}" var="oi"><p style="font-size:13px;color:#4a5a65;margin-bottom:4px">${oi.clothesName} x${oi.quantity} (${oi.size})</p></c:forEach></div><span style="font-size:20px;font-weight:700;color:#c0392b">&yen;${o.totalPrice}</span></div><div class="order-actions"><c:if test="${o.status=='unpaid'}"><a href="${pageContext.request.contextPath}/order?action=pay&id=${o.id}" class="btn btn-success btn-sm" onclick="return confirm('确认支付？')">支付</a></c:if><c:if test="${o.status=='shipped'}"><a href="${pageContext.request.contextPath}/order?action=receive&id=${o.id}" class="btn btn-success btn-sm" onclick="return confirm('确认收货？')">确认收货</a></c:if></div></div></c:forEach></div></div></body></html>