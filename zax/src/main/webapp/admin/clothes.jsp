<%@ page contentType="text/html;charset=UTF-8" language="java" %><%@ taglib prefix="c" uri="jakarta.tags.core" %>
<!DOCTYPE html><html><head><meta charset="UTF-8"><title>服装管理 - 智安行衣橱</title><link rel="stylesheet" href="${pageContext.request.contextPath}/css/admin.css"></head><body>
<header class="admin-topbar"><h2>后台管理</h2><ul class="top-links"><li><a href="${pageContext.request.contextPath}/admin/dashboard">控制面板</a></li><li><a href="${pageContext.request.contextPath}/admin/clothes" class="active">服装管理</a></li><li><a href="${pageContext.request.contextPath}/admin/orders">订单管理</a></li><li><a href="${pageContext.request.contextPath}/admin/users">用户管理</a></li><li><a href="${pageContext.request.contextPath}/clothes">返回前台</a></li></ul></header>
<div class="admin-main"><h1>服装管理</h1><div class="search-row"><form action="${pageContext.request.contextPath}/admin/clothes" style="display:flex;gap:10px;flex:1"><input type="text" name="keyword" placeholder="搜索服装..."><select name="category"><option value="">全部分类</option><c:forEach items="${categories}" var="c"><option value="${c}">${c}</option></c:forEach></select><button type="submit" class="btn btn-primary">搜索</button></form><a href="${pageContext.request.contextPath}/admin/clothes?action=add" class="btn btn-primary">添加服装</a></div><table class="data-table"><tr><th>ID</th><th>名称</th><th>分类</th><th>风格</th><th>价格</th><th>库存</th><th>操作</th></tr><c:forEach items="${clothesList}" var="c"><tr><td>${c.id}</td><td>${c.name}</td><td>${c.category}</td><td>${c.style}</td><td>&yen;${c.price}</td><td>${c.stock}</td><td><a href="${pageContext.request.contextPath}/admin/clothes?action=edit&id=${c.id}" class="btn btn-outline btn-sm">编辑</a> <a href="${pageContext.request.contextPath}/admin/clothes?action=delete&id=${c.id}" class="btn btn-danger btn-sm" onclick="return confirm('确定删除？')">删除</a></td></tr></c:forEach></table></div></body></html>