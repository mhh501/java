<%@ page contentType="text/html;charset=UTF-8" language="java" %><%@ taglib prefix="c" uri="jakarta.tags.core" %>
<!DOCTYPE html><html><head><meta charset="UTF-8"><title>智安行衣橱</title><link rel="stylesheet" href="${pageContext.request.contextPath}/css/style.css"></head><body>
<section class="hero"><h1>智安行衣橱</h1><p>发现你的专属风格</p><form class="hero-search" action="${pageContext.request.contextPath}/clothes"><input type="text" name="keyword" value="${keyword}" placeholder="🔍 搜索你喜欢的服装..."><select name="category"><option value="">全部分类</option><c:forEach items="${categories}" var="c"><option value="${c}" ${selectedCategory eq c?'selected':''}>${c}</option></c:forEach></select><select name="style"><option value="">全部风格</option><c:forEach items="${styles}" var="s"><option value="${s}" ${selectedStyle eq s?'selected':''}>${s}</option></c:forEach></select><button type="submit">搜索</button></form></section>
<nav class="nav-bar"><div class="logo">智安行衣橱</div><ul class="nav-links"><li><a href="${pageContext.request.contextPath}/clothes">首页</a></li><c:if test="${not empty sessionScope.loginUser}"><li><a href="${pageContext.request.contextPath}/cart">购物车</a></li><li><a href="${pageContext.request.contextPath}/order">订单</a></li><li><a href="${pageContext.request.contextPath}/profile">个人中心</a></li><c:if test="${sessionScope.userRole=='admin'}"><li><a href="${pageContext.request.contextPath}/admin/dashboard">后台</a></li></c:if><li><a href="${pageContext.request.contextPath}/login.jsp">退出</a></li></c:if><c:if test="${empty sessionScope.loginUser}"><li><a href="${pageContext.request.contextPath}/login.jsp">登录</a></li><li><a href="${pageContext.request.contextPath}/register.jsp">注册</a></li></c:if></ul><c:if test="${not empty sessionScope.loginUser}"><span class="user-info">${sessionScope.loginUser}</span></c:if></nav>
<div class="container"><div class="card-grid"><c:forEach items="${clothesList}" var="cloth"><div class="card"><a href="${pageContext.request.contextPath}/detail?id=${cloth.id}"><div class="card-img-wrap"><c:if test="${not empty cloth.imageUrl}"><img src="${pageContext.request.contextPath}/${cloth.imageUrl}"></c:if><div class="card-overlay"><h3>${cloth.name}</h3><div class="card-meta">${cloth.category} · ${cloth.style}</div></div></div></a><div class="card-info"><span class="price">&yen;${cloth.price}</span><span class="stock">库存: ${cloth.stock}</span><a href="${pageContext.request.contextPath}/detail?id=${cloth.id}" class="btn btn-outline btn-sm">查看</a></div></div></c:forEach><c:if test="${empty clothesList}"><div class="empty-state"><div class="icon">👕</div><p>暂无服装</p></div></c:if></div></div></body></html>